{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Leads",
  "version": "1.0.0",
  "identifier": "com.godavari.leads",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "python3 ../launcher.py",
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "title": "Godavari Leads",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "url": "http://localhost:8000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
